<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="emailAddress"
            android:hint="@string/login_email_hint"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="password"
            android:hint="@string/login_password_hint"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/deviceNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/login_device_name_hint"
            android:inputType="text"
            android:text="@string/default_device_name" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/login_button" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="@string/login_ready"
            android:textSize="16sp" />

        <Button
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout_button"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/productSearchContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/productSearchTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/product_search_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/productSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/product_search_hint"
                android:inputType="text" />

            <Button
                android:id="@+id/productSearchButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/product_search_button" />

            <TextView
                android:id="@+id/productSearchStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/product_search_ready"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/productSearchResultsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/supplierInvoiceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/supplierInvoiceTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/supplier_invoice_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/supplierInvoiceSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/supplier_invoice_search_hint"
                android:inputType="text" />

            <Button
                android:id="@+id/supplierInvoiceListButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/supplier_invoice_button" />

            <TextView
                android:id="@+id/supplierInvoiceListStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/supplier_invoice_ready"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/supplierInvoiceListResultsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/supplierInvoiceDetailButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/supplier_invoice_detail_button"
                android:visibility="gone" />

            <TextView
                android:id="@+id/supplierInvoiceDetailStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/supplier_invoice_detail_ready"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/supplierInvoiceDetailResultsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
